@model IReadOnlyList<Mesa>
@{
    ViewData["Title"] = "Registro de mesas";
    var busqueda = ViewBag.Busqueda as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Registro de mesas</h1>
    <a asp-action="Crear" class="btn btn-primary">Agregar mesa</a>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-8">
        <input type="text" name="busqueda" value="@busqueda" class="form-control"
               placeholder="Filtrar por número de mesa..." />
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
    </div>
    <div class="col-md-2 d-grid">
        <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info" role="alert">
        @if (string.IsNullOrWhiteSpace(busqueda))
        {
            <span>No hay mesas registradas todavía.</span>
        }
        else
        {
            <span>No se encontraron mesas con el número "@busqueda".</span>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle bg-white shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Número de mesa</th>
                    <th>Estado</th>
                    <th>Capacidad</th>
                    <th>Sección</th>
                    <th>Precio por persona</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mesa in Model)
                {
                    <tr>
                        <td>@mesa.NumeroMesa</td>
                        <td>
                            @if (mesa.Estado == (int)EstadoMesa.Disponible)
                            {
                                <span class="badge bg-success">@mesa.EstadoNombre</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@mesa.EstadoNombre</span>
                            }
                        </td>
                        <td>@mesa.Capacidad</td>
                        <td>@mesa.Seccion</td>
                        <td>@mesa.PrecioPorPersona.ToString("C")</td>
                        <td class="text-end">
                            <a asp-action="Editar" asp-route-id="@mesa.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
