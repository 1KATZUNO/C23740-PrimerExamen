@model IReadOnlyList<Mesa>
@{
    ViewData["Title"] = "Registro de mesas";
    var busqueda = ViewBag.Busqueda as string;
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3"><i class="bi bi-card-list text-primary me-2"></i>Registro de mesas</h1>
        <p class="subtitle">Administra el catálogo completo de mesas del restaurante.</p>
    </div>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Agregar mesa
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2">
            <div class="col-md-9">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="busqueda" value="@busqueda" class="form-control"
                           placeholder="Filtrar por número de mesa..." />
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary flex-fill">Buscar</button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Limpiar</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body empty-state">
            <i class="bi bi-inbox"></i>
            <p class="mb-0 mt-2">
                @if (string.IsNullOrWhiteSpace(busqueda))
                {
                    <span>No hay mesas registradas todavía.</span>
                }
                else
                {
                    <span>No se encontraron mesas con el número "<strong>@busqueda</strong>".</span>
                }
            </p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Número</th>
                        <th scope="col">Estado</th>
                        <th scope="col">Capacidad</th>
                        <th scope="col">Sección</th>
                        <th scope="col">Precio por persona</th>
                        <th scope="col" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mesa in Model)
                    {
                        <tr>
                            <td><strong>#@mesa.NumeroMesa</strong></td>
                            <td>
                                @if (mesa.Estado == (int)EstadoMesa.Disponible)
                                {
                                    <span class="badge estado bg-success-subtle text-success border border-success-subtle">
                                        <i class="bi bi-check2-circle"></i> @mesa.EstadoNombre
                                    </span>
                                }
                                else
                                {
                                    <span class="badge estado bg-warning-subtle text-warning-emphasis border border-warning-subtle">
                                        <i class="bi bi-bookmark-check"></i> @mesa.EstadoNombre
                                    </span>
                                }
                            </td>
                            <td><i class="bi bi-people text-muted"></i> @mesa.Capacidad</td>
                            <td>@mesa.Seccion</td>
                            <td>@mesa.PrecioPorPersona.ToString("C")</td>
                            <td class="text-end">
                                <a asp-action="Editar" asp-route-id="@mesa.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <p class="text-muted small mt-2 mb-0">Total: @Model.Count mesa@(Model.Count == 1 ? "" : "s").</p>
}
