@model IReadOnlyList<Mesa>
@{
    ViewData["Title"] = "Mesas reservadas";
    var busqueda = ViewBag.Busqueda as string;
}

<div class="page-header mb-4">
    <h1 class="h3"><i class="bi bi-bookmark-check text-warning me-2"></i>Mesas reservadas</h1>
    <p class="subtitle">Reservas activas. Puedes ver el detalle o liberar la mesa.</p>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2">
            <div class="col-md-9">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="busqueda" value="@busqueda" class="form-control"
                           placeholder="Filtrar por nombre del cliente..." />
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary flex-fill">Buscar</button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Limpiar</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body empty-state">
            <i class="bi bi-bookmark-x"></i>
            <p class="mb-0 mt-2">
                @if (string.IsNullOrWhiteSpace(busqueda))
                {
                    <span>Actualmente no hay mesas reservadas.</span>
                }
                else
                {
                    <span>No hay reservas a nombre de "<strong>@busqueda</strong>".</span>
                }
            </p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Número</th>
                        <th scope="col">Estado</th>
                        <th scope="col">Capacidad</th>
                        <th scope="col">Sección</th>
                        <th scope="col">Cliente</th>
                        <th scope="col">Fecha</th>
                        <th scope="col">Comensales</th>
                        <th scope="col" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mesa in Model)
                    {
                        <tr>
                            <td><strong>#@mesa.NumeroMesa</strong></td>
                            <td>
                                <span class="badge estado bg-warning-subtle text-warning-emphasis border border-warning-subtle">
                                    <i class="bi bi-bookmark-check"></i> @mesa.EstadoNombre
                                </span>
                            </td>
                            <td><i class="bi bi-people text-muted"></i> @mesa.Capacidad</td>
                            <td>@mesa.Seccion</td>
                            <td><i class="bi bi-person text-muted"></i> @mesa.NombreCliente</td>
                            <td>
                                <i class="bi bi-calendar-event text-muted"></i>
                                @(mesa.FechaReserva?.ToString("dd/MM/yyyy"))
                            </td>
                            <td>@mesa.CantidadComensales</td>
                            <td class="text-end tabla-acciones">
                                <a asp-action="Detalle" asp-route-id="@mesa.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i> Detalle
                                </a>
                                <form asp-action="Liberar" asp-route-id="@mesa.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Liberar la mesa @mesa.NumeroMesa?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-unlock"></i> Liberar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <p class="text-muted small mt-2 mb-0">Total: @Model.Count reserva@(Model.Count == 1 ? "" : "s") activa@(Model.Count == 1 ? "" : "s").</p>
}
