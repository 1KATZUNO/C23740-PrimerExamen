@model IReadOnlyList<Mesa>
@{
    ViewData["Title"] = "Mesas reservadas";
    var busqueda = ViewBag.Busqueda as string;
}

<h1 class="h3 mb-4">Mesas reservadas</h1>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-8">
        <input type="text" name="busqueda" value="@busqueda" class="form-control"
               placeholder="Filtrar por nombre del cliente..." />
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
    </div>
    <div class="col-md-2 d-grid">
        <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info" role="alert">
        @if (string.IsNullOrWhiteSpace(busqueda))
        {
            <span>Actualmente no hay mesas reservadas.</span>
        }
        else
        {
            <span>No hay reservas a nombre de "@busqueda".</span>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle bg-white shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Número de mesa</th>
                    <th>Estado</th>
                    <th>Capacidad</th>
                    <th>Sección</th>
                    <th>Nombre del cliente</th>
                    <th>Fecha de la reserva</th>
                    <th>Comensales</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mesa in Model)
                {
                    <tr>
                        <td>@mesa.NumeroMesa</td>
                        <td><span class="badge bg-warning text-dark">@mesa.EstadoNombre</span></td>
                        <td>@mesa.Capacidad</td>
                        <td>@mesa.Seccion</td>
                        <td>@mesa.NombreCliente</td>
                        <td>@(mesa.FechaReserva?.ToString("dd/MM/yyyy"))</td>
                        <td>@mesa.CantidadComensales</td>
                        <td class="text-end tabla-acciones">
                            <a asp-action="Detalle" asp-route-id="@mesa.Id" class="btn btn-sm btn-outline-secondary">Detalle</a>
                            <form asp-action="Liberar" asp-route-id="@mesa.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('¿Liberar la mesa @mesa.NumeroMesa?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-success">Liberar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
