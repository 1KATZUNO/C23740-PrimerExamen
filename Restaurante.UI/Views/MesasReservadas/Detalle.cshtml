@model Mesa
@{
    ViewData["Title"] = "Detalle de la reserva";
}

<h1 class="h3 mb-4">Detalle de la reserva — Mesa #@Model.NumeroMesa</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Número de mesa</dt>
            <dd class="col-sm-8">@Model.NumeroMesa</dd>

            <dt class="col-sm-4">Estado</dt>
            <dd class="col-sm-8">
                @if (Model.Estado == (int)EstadoMesa.Disponible)
                {
                    <span class="badge bg-success">@Model.EstadoNombre</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">@Model.EstadoNombre</span>
                }
            </dd>

            <dt class="col-sm-4">Capacidad</dt>
            <dd class="col-sm-8">@Model.Capacidad</dd>

            <dt class="col-sm-4">Sección</dt>
            <dd class="col-sm-8">@Model.Seccion</dd>

            <dt class="col-sm-4">Nombre del cliente</dt>
            <dd class="col-sm-8">@Model.NombreCliente</dd>

            <dt class="col-sm-4">Identificación del cliente</dt>
            <dd class="col-sm-8">@Model.IdentificacionCliente</dd>

            <dt class="col-sm-4">Fecha de la reserva</dt>
            <dd class="col-sm-8">@(Model.FechaReserva?.ToString("dd/MM/yyyy"))</dd>

            <dt class="col-sm-4">Cantidad de comensales</dt>
            <dd class="col-sm-8">@Model.CantidadComensales</dd>

            <dt class="col-sm-4">Monto del depósito de garantía</dt>
            <dd class="col-sm-8">@(Model.DepositoDeGarantia?.ToString("C"))</dd>
        </dl>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    @if (Model.Estado == (int)EstadoMesa.Reservada)
    {
        <form asp-action="Liberar" asp-route-id="@Model.Id" method="post" class="d-inline"
              onsubmit="return confirm('¿Liberar la mesa @Model.NumeroMesa?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-success">Liberar mesa</button>
        </form>
    }
</div>
