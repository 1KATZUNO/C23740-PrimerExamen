@model IReadOnlyList<Mesa>
@{
    ViewData["Title"] = "Mesas disponibles";
    var busqueda = ViewBag.Busqueda as string;
}

<h1 class="h3 mb-4">Mesas disponibles</h1>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-8">
        <input type="text" name="busqueda" value="@busqueda" class="form-control"
               placeholder="Filtrar por número de mesa..." />
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
    </div>
    <div class="col-md-2 d-grid">
        <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info" role="alert">
        @if (string.IsNullOrWhiteSpace(busqueda))
        {
            <span>Actualmente no hay mesas disponibles.</span>
        }
        else
        {
            <span>No hay mesas disponibles con el número "@busqueda".</span>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle bg-white shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Número de mesa</th>
                    <th>Estado</th>
                    <th>Capacidad</th>
                    <th>Sección</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mesa in Model)
                {
                    <tr>
                        <td>@mesa.NumeroMesa</td>
                        <td><span class="badge bg-success">@mesa.EstadoNombre</span></td>
                        <td>@mesa.Capacidad</td>
                        <td>@mesa.Seccion</td>
                        <td class="text-end">
                            <a asp-action="Reservar" asp-route-id="@mesa.Id" class="btn btn-sm btn-primary">Reservar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
