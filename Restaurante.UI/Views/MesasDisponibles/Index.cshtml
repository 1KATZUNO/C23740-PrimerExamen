@model IReadOnlyList<Mesa>
@{
    ViewData["Title"] = "Mesas disponibles";
    var busqueda = ViewBag.Busqueda as string;
}

<div class="page-header mb-4">
    <h1 class="h3"><i class="bi bi-check2-circle text-success me-2"></i>Mesas disponibles</h1>
    <p class="subtitle">Mesas listas para ser reservadas por un cliente.</p>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2">
            <div class="col-md-9">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="busqueda" value="@busqueda" class="form-control"
                           placeholder="Filtrar por número de mesa..." />
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary flex-fill">Buscar</button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Limpiar</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body empty-state">
            <i class="bi bi-emoji-frown"></i>
            <p class="mb-0 mt-2">
                @if (string.IsNullOrWhiteSpace(busqueda))
                {
                    <span>Actualmente no hay mesas disponibles.</span>
                }
                else
                {
                    <span>No hay mesas disponibles con el número "<strong>@busqueda</strong>".</span>
                }
            </p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Número</th>
                        <th scope="col">Estado</th>
                        <th scope="col">Capacidad</th>
                        <th scope="col">Sección</th>
                        <th scope="col" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mesa in Model)
                    {
                        <tr>
                            <td><strong>#@mesa.NumeroMesa</strong></td>
                            <td>
                                <span class="badge estado bg-success-subtle text-success border border-success-subtle">
                                    <i class="bi bi-check2-circle"></i> @mesa.EstadoNombre
                                </span>
                            </td>
                            <td><i class="bi bi-people text-muted"></i> @mesa.Capacidad</td>
                            <td>@mesa.Seccion</td>
                            <td class="text-end">
                                <a asp-action="Reservar" asp-route-id="@mesa.Id" class="btn btn-sm btn-primary">
                                    <i class="bi bi-bookmark-plus"></i> Reservar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <p class="text-muted small mt-2 mb-0">Total: @Model.Count mesa@(Model.Count == 1 ? "" : "s") disponible@(Model.Count == 1 ? "" : "s").</p>
}
