@model ReservaViewModel
@{
    ViewData["Title"] = "Reservar mesa";
}

<h1 class="h3 mb-4">Reservar mesa #@Model.NumeroMesa</h1>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Reservar" method="post" class="card shadow-sm">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                <input type="hidden" asp-for="MesaId" />
                <input type="hidden" asp-for="NumeroMesa" />
                <input type="hidden" asp-for="PrecioPorPersona" />

                <div class="alert alert-secondary">
                    <strong>Precio por persona:</strong> @Model.PrecioPorPersona.ToString("C")
                </div>

                <div class="mb-3">
                    <label asp-for="IdentificacionCliente" class="form-label"></label>
                    <input asp-for="IdentificacionCliente" class="form-control" autocomplete="off" />
                    <span asp-validation-for="IdentificacionCliente" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NombreCliente" class="form-label"></label>
                    <input asp-for="NombreCliente" class="form-control" autocomplete="off" />
                    <span asp-validation-for="NombreCliente" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FechaReserva" class="form-label"></label>
                    <input asp-for="FechaReserva" type="date" class="form-control" />
                    <span asp-validation-for="FechaReserva" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CantidadComensales" class="form-label"></label>
                    <input asp-for="CantidadComensales" class="form-control" />
                    <span asp-validation-for="CantidadComensales" class="text-danger"></span>
                    <div class="form-text">
                        El depósito de garantía se calcula automáticamente al confirmar la reserva.
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Confirmar reserva</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
