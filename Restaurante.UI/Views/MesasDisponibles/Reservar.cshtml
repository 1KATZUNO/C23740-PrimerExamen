@model ReservaViewModel
@{
    ViewData["Title"] = "Reservar mesa";
}

<div class="page-header mb-4">
    <h1 class="h3"><i class="bi bi-bookmark-plus text-primary me-2"></i>Reservar mesa #@Model.NumeroMesa</h1>
    <p class="subtitle">El depósito de garantía se calcula automáticamente al confirmar la reserva.</p>
</div>

<div class="row">
    <div class="col-md-8 col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <span><i class="bi bi-person-vcard me-1"></i> Datos del cliente</span>
                <span class="badge bg-light text-dark border">
                    Precio por persona: <strong>@Model.PrecioPorPersona.ToString("C")</strong>
                </span>
            </div>
            <div class="card-body">
                <form asp-action="Reservar" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <input type="hidden" asp-for="MesaId" />
                    <input type="hidden" asp-for="NumeroMesa" />
                    <input type="hidden" asp-for="PrecioPorPersona" />

                    <div class="mb-3">
                        <label asp-for="IdentificacionCliente" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-credit-card-2-front"></i></span>
                            <input asp-for="IdentificacionCliente" class="form-control" autocomplete="off" />
                        </div>
                        <span asp-validation-for="IdentificacionCliente" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NombreCliente" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="NombreCliente" class="form-control" autocomplete="off" />
                        </div>
                        <span asp-validation-for="NombreCliente" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaReserva" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                                <input asp-for="FechaReserva" type="date" class="form-control" />
                            </div>
                            <span asp-validation-for="FechaReserva" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CantidadComensales" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-people-fill"></i></span>
                                <input asp-for="CantidadComensales" class="form-control" />
                            </div>
                            <span asp-validation-for="CantidadComensales" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="alert alert-info py-2 px-3 small mb-4">
                        <i class="bi bi-info-circle me-1"></i>
                        Cálculo del depósito: <strong>100%</strong> si hay menos de 4 comensales,
                        <strong>75%</strong> entre 4 y 7, y <strong>50%</strong> para 8 o más.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-bookmark-check me-1"></i> Confirmar reserva
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
